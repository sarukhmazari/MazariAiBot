# Katabump Environment Variables
# Copy this file to .env and fill in your values

# Session storage path (Katabump will manage this)
SESSION_PATH=./session

# Owner phone number (with country code, no + or spaces)
# Example: 911234567890 for US, 923232391033 for Pakistan
OWNER_NUMBER=923232391033

# Bot Configuration
BOT_NAME=MAZARI BOT
BOT_PACKNAME=Mazari Bot
BOT_AUTHOR=Sarukh Mazari
BOT_OWNER=Sarukh Mazari

# Bot mode (public or private)
BOT_MODE=public

# Optional: Theme emoji
THEME_EMOJI=•

# Optional: Giphy API Key (for GIF features)
GIPHY_API_KEY=qnl7ssQChTdPjsKta2Ax2LMaGXz303tq

# Optional: Store settings
MAX_STORE_MESSAGES=20
STORE_WRITE_INTERVAL=10000
